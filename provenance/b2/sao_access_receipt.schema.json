{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "accepted_at_utc": {
      "format": "date-time",
      "type": "string"
    },
    "accepted_by": {
      "minLength": 1,
      "type": "string"
    },
    "license_identifier": {
      "minLength": 1,
      "type": "string"
    },
    "license_text_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "model_id": {
      "const": "stabilityai/stable-audio-open-1.0"
    },
    "resolved_provider_revision": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "snapshot_manifest_path": {
      "minLength": 1,
      "type": "string"
    },
    "snapshot_manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "user_confirmed_acceptance": {
      "const": true
    }
  },
  "required": [
    "schema_version",
    "model_id",
    "resolved_provider_revision",
    "accepted_by",
    "accepted_at_utc",
    "user_confirmed_acceptance",
    "license_identifier",
    "license_text_sha256",
    "snapshot_manifest_path",
    "snapshot_manifest_sha256"
  ],
  "title": "Stable Audio Open 1.0 non-secret access receipt",
  "type": "object"
}
